# Studio uses this manifest to identify, validate, install, and update the package.
# Replace every placeholder before releasing a package based on this template.
# PACKAGE_CHANNEL defines the update channel or branch in PACKAGE_SOURCE.

##> vendor/package-template manifest ###
PACKAGE_AUTHOR="Vendor Name"
PACKAGE_SLUG=package-template
PACKAGE_NAME="Package Template"
PACKAGE_DESCRIPTION="Template package for Studio package development"
PACKAGE_VERSION=0.1.0
PACKAGE_SCOPE=module
PACKAGE_DEPENDENCIES=[["system","0.2.6"]]
PACKAGE_LICENSE=MIT
PACKAGE_HOMEPAGE=https://example.com
PACKAGE_IMAGE=assets/preview.svg
PACKAGE_CHANNEL=main
PACKAGE_SOURCE=https://example.com/vendor/package-template
PACKAGE_DATE=2026-06-19
##< vendor/package-template manifest ###
